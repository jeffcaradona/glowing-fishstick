{
  "name": "glowing-fishstick-tasks-api",
  "private": true,
  "version": "1.0.1",
  "description": "A local development application to help build the core modules",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --watch src --watch ../core/api/src --watch ../core/shared/src --ext js,mjs,cjs,json,eta src/server.js",
    "test": "vitest run --reporter=verbose tests/unit tests/integration",
    "test:unit": "vitest run --reporter=verbose tests/unit",
    "test:integration": "vitest run --reporter=verbose tests/integration"
  },
  "dependencies": {
    "@glowing-fishstick/api": "^0.1.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.13",
    "supertest": "^7.1.0"
  }
}
