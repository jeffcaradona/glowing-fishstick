{
  "name": "@glowing-fishstick/api",
  "version": "0.1.3",
  "description": "Core API factory and route composition module for glowing-fishstick",
  "keywords": [
    "express",
    "api",
    "rest",
    "factory",
    "glowing-fishstick"
  ],
  "homepage": "https://github.com/jeffcaradona/glowing-fishstick#readme",
  "bugs": {
    "url": "https://github.com/jeffcaradona/glowing-fishstick/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffcaradona/glowing-fishstick.git"
  },
  "license": "MIT",
  "author": "Jeff Caradona <jeffcaradona@gmail.com>",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "npm run test:integration",
    "test:integration": "vitest run --reporter=verbose tests/integration",
    "coverage": "c8 --all --include=src/**/*.js --exclude=tests/** --reporter=text --reporter=lcov --report-dir=../../coverage/core-api vitest run --reporter=verbose tests/integration",
    "lint": "eslint ."
  },
  "dependencies": {
    "@glowing-fishstick/shared": "^0.1.3",
    "express": "^5.2.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3"
  }
}