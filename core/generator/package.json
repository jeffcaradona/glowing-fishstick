{
  "name": "@glowing-fishstick/generator",
  "version": "0.1.2",
  "private": false,
  "description": "CLI template generator for glowing-fishstick applications",
  "keywords": [
    "template",
    "generator",
    "express",
    "cli",
    "glowing-fishstick"
  ],
  "homepage": "https://github.com/jeffcaradona/glowing-fishstick#readme",
  "bugs": {
    "url": "https://github.com/jeffcaradona/glowing-fishstick/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffcaradona/glowing-fishstick.git"
  },
  "license": "MIT",
  "author": "Jeff Caradona <jeffcaradona@gmail.com>",
  "type": "module",
  "main": "src/generator.js",
  "bin": {
    "fishstick-create": "./bin/cli.js"
  },
  "exports": {
