{
  "name": "@glowing-fishstick/shared",
  "version": "0.1.5",
  "description": "Shared server factory, lifecycle hooks, JWT, and admin middleware for glowing-fishstick",
  "keywords": [
    "express",
    "shared",
    "factory",
    "server",
    "glowing-fishstick"
  ],
  "homepage": "https://github.com/jeffcaradona/glowing-fishstick#readme",
  "bugs": {
    "url": "https://github.com/jeffcaradona/glowing-fishstick/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffcaradona/glowing-fishstick.git"
  },
  "license": "MIT",
  "author": "Jeff Caradona <jeffcaradona@gmail.com>",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js"
    },
    "./testing": {
      "import": "./src/testing/security-helpers.js",
      "types": "./src/testing/security-helpers.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "vitest run --reporter=verbose tests/unit",
    "coverage": "c8 --all --include=src/**/*.js --exclude=tests/** --reporter=text --reporter=lcov --report-dir=../../coverage/core-shared vitest run --reporter=verbose tests/unit"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "@glowing-fishstick/logger": "^0.1.4"
  },
  "peerDependencies": {
    "express": "^5.2.1",
    "pino": "^9.0.0"
  }
}
