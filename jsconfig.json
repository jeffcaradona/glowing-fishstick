{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@glowing-fishstick/app": ["core/web-app/index.js"],
      "@glowing-fishstick/api": ["core/service-api/index.js"],
      "@glowing-fishstick/generator": ["core/generator/index.js"],
      "@glowing-fishstick/logger": ["core/modules/logger/index.js"],
      "@glowing-fishstick/shared": ["core/shared/index.js"],
      "@glowing-fishstick/workflows": ["core/modules/workflows/index.js"]
    }
  },
  "include": [
    "sandbox/app/src/**/*.js/**/*.js",
    "sandbox/api/src/**/*.js/**/*.js",
    "core/web-app/src/**/*.js",
    "core/service-api/src/**/*.js",
    "core/generator/src/**/*.js",
    "core/shared/src/**/*.js",
    "core/modules/logger/src/**/*.js",
    "core/modules/workflows/src/**/*.js"
  ],
  "exclude": ["node_modules"]
}
