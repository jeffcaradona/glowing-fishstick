{
  "name": "glowing-fishstick",
  "version": "0.1.3",
  "description": "An example of replacing distributed Express templates with a composable module",
  "keywords": [
    "template",
    "module",
    "app",
    "api",
    "generator",
    "glowing-fishstick"
  ],
  "workspaces": [
    "sandbox/api",
    "sandbox/app",
    "core/web-app",
    "core/service-api",
    "core/generator",
    "core/shared",
    "core/modules/logger"
  ],
  "homepage": "https://github.com/jeffcaradona/glowing-fishstick#readme",
  "bugs": {
    "url": "https://github.com/jeffcaradona/glowing-fishstick/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffcaradona/glowing-fishstick.git"
  },
  "license": "MIT",
  "author": "Jeff Caradona <jeffcaradona@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "files": [],
  "scripts": {
    "start:app": "npm run start --workspace sandbox/app",
    "dev:app": "npm run dev --workspace sandbox/app",
    "start:api": "npm run start --workspace sandbox/api",
    "dev:api": "npm run dev --workspace sandbox/api",
    "test": "npm run test:all",
    "test:unit": "npm run test:unit --workspace core/shared",
    "test:integration": "npm run test:integration --workspace core/web-app",
    "test:smoke": "npm run test:smoke --workspace core/web-app",
    "test:api": "npm run test --workspace core/service-api",
    "test:all": "npm run test --workspace core/shared && npm run test --workspace core/web-app && npm run test --workspace core/service-api && npm run test --workspace core/generator",
    "coverage:shared": "npm run coverage --workspace core/shared",
    "coverage:app": "npm run coverage --workspace core/web-app",
    "coverage:api": "npm run coverage --workspace core/service-api",
    "coverage:scan": "npm run coverage:shared && npm run coverage:app && npm run coverage:api",
    "benchmark:core": "node core/benchmarks/run.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "cs": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "glob": "^13.0.6",
    "minimatch": "^10.2.4",
    "test-exclude": "^7.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "autocannon": "^8.0.0",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
